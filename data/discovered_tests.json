    {
      "id": "TC-DYN-004",
      "module": "Checkout",
      "scenarioName": "Validate event guest count constraint under min limit (50)",
      "route": "/customer/checkout",
      "component": "Checkout",
      "prerequisiteRoute": "/caterer-menu/1",
      "prerequisiteActions": [
        {
          "type": "click",
          "selector": "(//button[contains(., \"Add\")])[1]"
        },
        {
          "type": "click",
          "selector": "//span[contains(., \"Items\")]"
        }
      ],
      "actions": [
        {
          "type": "type",
          "selector": "input[type=\"number\"]",
          "value": "49"
        },
        {
          "type": "click",
          "selector": "button[type=\"submit\"]"
        }
      ],
      "expectedResult": "Form submission blocked by HTML5 min constraint (50) on input[type=\"number\"]",
      "type": "negative"
    },
